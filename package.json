{
  "name": "zeroclaw-music",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "node --env-file=.env server.js",
    "dev:full": "sh -c 'trap \"kill $(jobs -p)\" EXIT; npm run dev:backend & npm run dev:frontend'",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node --env-file=.env server.js",
    "seed": "node --env-file=.env scripts/seed-supabase.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "essentia.js": "^0.1.3",
    "express": "^5.2.1",
    "music-metadata": "^11.13.0",
    "openai": "^6.44.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
